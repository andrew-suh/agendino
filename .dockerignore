# Keep the build context small — these don't belong in the image.
.git
.github
.idea
__pycache__/
*.pyc

# Local secrets & env
.env

# Runtime data (mounted as volumes at runtime, not baked into the image)
local_recordings/
settings/
*.db
*.hda

# Tests, coverage, docs — not needed at runtime
tests/
htmlcov/
docs/

# Plan/scratch
*.md
!README.md
