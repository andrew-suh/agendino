# ── Gemini (transcription, summarization, RAG) ───────────────────────────
GEMINI_API_KEY=your-gemini-api-key
# gemini-3-flash-preview | gemini-3.1-pro-preview | gemini-2.5-pro | gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Transcription-only model (falls back to GEMINI_MODEL) — e.g. a cheaper/faster model
#GEMINI_TRANSCRIPTION_MODEL=gemini-3-flash-preview

# ── Summarization: gemini | claude ───────────────────────────────────────
SUMMARIZATION_PROVIDER=gemini
#ANTHROPIC_API_KEY=sk-ant-...               # required for claude
#CLAUDE_MODEL=claude-sonnet-4-6             # or opus-4-8, haiku-4-5

# ── Knowledge base / RAG ─────────────────────────────────────────────────
# Embeddings: gemini (cloud) | ollama (dockerized, shared) | local (in-process, non-Docker dev)
EMBEDDING_PROVIDER=gemini
# Generation: gemini | ollama | local (ollama==local). Unset → follows EMBEDDING_PROVIDER.
#RAG_PROVIDER=gemini

# Ollama (provider=ollama/local). Dockerized: use the service name; models auto-pull on first start.
# Host Ollama instead: http://host.docker.internal:11434 + run Ollama with OLLAMA_HOST=0.0.0.0.
#OLLAMA_BASE_URL=http://ollama:11434
#OLLAMA_EMBEDDING_MODEL=bge-m3
#OLLAMA_MODEL=qwen2.5:7b                    # GPU & CPU; qwen2.5:3b = faster CPU

# In-process embeddings (EMBEDDING_PROVIDER=local; needs `pip install sentence-transformers`):
#LOCAL_EMBEDDING_MODEL=BAAI/bge-m3          # long-context (8192)
#LOCAL_EMBEDDING_DEVICE=auto                # auto|cpu|cuda|mps

# Changing the embedding provider/model clears the vector store on startup — reload from Knowledge page.

# ── Whisper (local transcription) ────────────────────────────────────────
# tiny | base | small | medium | large-v3 | turbo | distil-*.en (English, faster)
WHISPER_MODEL_SIZE=small
#WHISPER_DEVICE=auto                        # non-Docker only: auto|cpu|cuda|mps
#WHISPER_COMPUTE_TYPE=auto                  # auto|int8|float16|float32

# ── Local diarization (speaker labels for local Whisper; pyannote) ───────
# Adds ~2-3 GB RAM (or VRAM) when loaded; transcription fails fast if enabled
# without HF_TOKEN and the models aren't cached yet.
#LOCAL_DIARIZATION_ENABLED=true
# One-time download of the gated pyannote models — create a free token at
# hf.co/settings/tokens and accept the terms on hf.co/pyannote/speaker-diarization-3.1
# and hf.co/pyannote/segmentation-3.0. Not needed once the models are cached.
#HF_TOKEN=hf_...
#DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
# auto|cpu|cuda — set to cpu to keep VRAM flat while Whisper uses the GPU.
# Default: follows WHISPER_DEVICE (in Docker this is the only split-device knob,
# since compose hardcodes WHISPER_DEVICE=auto on the celery service).
#DIARIZATION_DEVICE=cpu
# GPU Toggle (Linux+NVIDIA)
#GPU=1
COMPOSE_FILE=compose.yaml${GPU:+:compose.gpu.yaml} #  COMPOSE_FILE sep ':' Linux, ';' Windows — see docs/docker.md

# ── Notion ───────────────────────────────────────────────────────────────
NOTION_API_KEY=ntn_...
NOTION_PAGE_ID=your-parent-page-id-here

# ── App ──────────────────────────────────────────────────────────────────
DATABASE_NAME=agendino.db
AUTH_ENABLED=false
#AUTH_SECRET_KEY=your-secret-key-here

# ── Deployment / tuning (optional; defaults shown) ───────────────────────
#INTERNAL_IP=127.0.0.1                      # Traefik host/domain
#CELERY_BROKER_URL=redis://localhost:6379/0
#WEB_CONCURRENCY=4                          # uvicorn workers + upload concurrency
#CELERY_CONCURRENCY=1                       # parallel transcription jobs
#TASK_LOCK_TTL=1860                         # lock safety TTL (seconds)
