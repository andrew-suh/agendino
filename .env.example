# Required - Google Gemini API key (transcription, summarization, RAG, recaps)
GEMINI_API_KEY=your-gemini-api-key
# Options:
#      gemini-3.1-pro-preview, gemini-3-flash-preview, gemini-3.1-flash-lite-preview
#      gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
# Options: gemini-embedding-2-preview, gemini-embedding-001
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Summarization provider. Transcription always uses Gemini/Whisper — Claude's API
# cannot accept audio, so it is only available for summarization.
# Options: gemini, claude
SUMMARIZATION_PROVIDER=gemini
# Required only when SUMMARIZATION_PROVIDER=claude
#ANTHROPIC_API_KEY=sk-ant-...
# Options: claude-sonnet-4-6 (default), claude-opus-4-8, claude-haiku-4-5
#CLAUDE_MODEL=claude-sonnet-4-6

DATABASE_NAME=agendino.db

NOTION_API_KEY=ntn_...
NOTION_PAGE_ID=your-parent-page-id-here

# Options: tiny, base, small, medium, large, large-v2, large-v3, turbo
WHISPER_MODEL_SIZE=small
# Options: auto (GPU if available, else CPU), cpu, cuda, mps
WHISPER_DEVICE=cpu
# Options: auto, int8, int8_float16, float16, float32
WHISPER_COMPUTE_TYPE=auto

# Optional - enable login authentication (default: false)
AUTH_ENABLED=false

# ── Deployment / tuning (optional; sensible defaults shown) ──────────────
# Redis broker+backend for Celery and task locks. Compose sets this to the
# redis service; only override for a non-default Redis (e.g. local non-Docker).
#CELERY_BROKER_URL=redis://localhost:6379/0
# uvicorn workers AND the parallel upload concurrency in the dashboard.
#WEB_CONCURRENCY=4
# Parallel transcription/summarization jobs on the Celery worker.
# Tune per CPU/GPU — see docs/docker.md.
#CELERY_CONCURRENCY=1
# Safety-net TTL (seconds) for task locks; should exceed the task time limit.
#TASK_LOCK_TTL=1860
# Enable GPU acceleration for Whisper (Linux host with NVIDIA Container Toolkit).
# Uncommenting this makes plain `docker compose up` use the GPU override.
# Leave commented for CPU. See docs/docker.md. (Path separator is ':' on Linux.)
#COMPOSE_FILE=compose.yaml:compose.gpu.yaml
