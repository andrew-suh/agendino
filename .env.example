GEMINI_API_KEY=AIzaS
# Options:
#      gemini-3.1-pro-preview, gemini-3-flash-preview, gemini-3.1-flash-lite-preview
#      gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
# Options: gemini-embedding-2-preview, gemini-embedding-001
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Summarization provider. Transcription always uses Gemini/Whisper — Claude's API
# cannot accept audio, so it is only available for summarization.
# Options: gemini, claude
SUMMARIZATION_PROVIDER=gemini
# Required only when SUMMARIZATION_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
# Options: claude-sonnet-4-6 (default), claude-opus-4-8, claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6

DATABASE_NAME=agendino.db

NOTION_API_KEY=ntn_...
NOTION_PAGE_ID=your-parent-page-id-here

# Options: tiny, base, small, medium, large, large-v2, large-v3, turbo
WHISPER_MODEL_SIZE=small
# Options: cpu, cuda, mps
WHISPER_DEVICE=cpu
# Options: auto, int8, int8_float16, float16, float32
WHISPER_COMPUTE_TYPE=auto

# Authentication – secret key for session signing
AUTH_SECRET_KEY=your-secret-key-here
AUTH_ENABLED=false
