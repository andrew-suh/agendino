# ── Gemini (transcription, summarization, RAG) ───────────────────────────
GEMINI_API_KEY=your-gemini-api-key
# gemini-3-flash-preview | gemini-3.1-pro-preview | gemini-2.5-pro | gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Transcription-only model (falls back to GEMINI_MODEL) — e.g. a cheaper/faster model
#GEMINI_TRANSCRIPTION_MODEL=gemini-3-flash-preview

# ── Summarization: gemini | claude ───────────────────────────────────────
SUMMARIZATION_PROVIDER=gemini
#ANTHROPIC_API_KEY=sk-ant-...               # required for claude
#CLAUDE_MODEL=claude-sonnet-4-6             # or opus-4-8, haiku-4-5

# ── Knowledge base / RAG: gemini | ollama | local ────────────────────────
# Embeddings provider:
#   gemini  - cloud (Google embedding API)
#   ollama  - offline, served by the dockerized Ollama container (one shared model, recommended)
#   local   - offline, in-process sentence-transformers (non-Docker dev; needs `pip install
#             sentence-transformers`). Use a LONG-CONTEXT model — summaries often exceed 512 tokens.
EMBEDDING_PROVIDER=gemini
# Answer generation + mind maps. Values: gemini (cloud) | ollama (Docker) | local (non-Docker host
# Ollama) — ollama and local are synonyms (both use OLLAMA_BASE_URL). If left unset it follows
# EMBEDDING_PROVIDER: Ollama generation when EMBEDDING_PROVIDER=ollama, else Gemini.
#RAG_PROVIDER=gemini

# Ollama (EMBEDDING_PROVIDER=ollama and/or RAG_PROVIDER=local). Dockerized (default): use the service
# name below; the container auto-pulls these models on first start (idempotent). Host-installed Ollama:
# use http://host.docker.internal:11434 and start Ollama with OLLAMA_HOST=0.0.0.0 (host env var, not here).
#OLLAMA_BASE_URL=http://ollama:11434
#OLLAMA_EMBEDDING_MODEL=bge-m3              # embedding model (8192 ctx)
#OLLAMA_MODEL=qwen2.5:7b                    # generation model — good for GPU & CPU; qwen2.5:3b = faster CPU

# In-process embeddings (EMBEDDING_PROVIDER=local only):
#LOCAL_EMBEDDING_MODEL=BAAI/bge-m3          # long-context (8192); avoids truncating long summaries
#LOCAL_EMBEDDING_DEVICE=auto                # auto|cpu|cuda|mps

# NOTE: changing the embedding provider/model invalidates existing vectors; the store auto-clears on
# startup and you must reload summaries from the Knowledge page.

# ── Whisper (local transcription) ────────────────────────────────────────
# tiny | base | small | medium | large-v3 | turbo | distil-*.en (English, faster)
WHISPER_MODEL_SIZE=small
#WHISPER_DEVICE=auto                        # non-Docker only: auto|cpu|cuda|mps
#WHISPER_COMPUTE_TYPE=auto                  # auto|int8|float16|float32
# GPU Toggle (Linux+NVIDIA)
#GPU=1
COMPOSE_FILE=compose.yaml${GPU:+:compose.gpu.yaml} #  COMPOSE_FILE sep ':' Linux, ';' Windows — see docs/docker.md

# ── Notion ───────────────────────────────────────────────────────────────
NOTION_API_KEY=ntn_...
NOTION_PAGE_ID=your-parent-page-id-here

# ── App ──────────────────────────────────────────────────────────────────
DATABASE_NAME=agendino.db
AUTH_ENABLED=false
#AUTH_SECRET_KEY=your-secret-key-here

# ── Deployment / tuning (optional; defaults shown) ───────────────────────
#INTERNAL_IP=127.0.0.1                      # Traefik host/domain
#CELERY_BROKER_URL=redis://localhost:6379/0
#WEB_CONCURRENCY=4                          # uvicorn workers + upload concurrency
#CELERY_CONCURRENCY=1                       # parallel transcription jobs
#TASK_LOCK_TTL=1860                         # lock safety TTL (seconds)
