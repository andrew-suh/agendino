# ══ Required — the app won't start without these ═════════════════════════
GEMINI_API_KEY=your-gemini-api-key
# gemini-3-flash-preview | gemini-3.1-pro-preview | gemini-2.5-pro | gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
DATABASE_NAME=agendino.db
NOTION_API_KEY=ntn_...
NOTION_PAGE_ID=your-parent-page-id-here

# ══ AI providers (optional) ══════════════════════════════════════════════
# Transcription-only model (falls back to GEMINI_MODEL) — e.g. a cheaper/faster model
#GEMINI_TRANSCRIPTION_MODEL=gemini-3-flash-preview
# Summarization: gemini | claude
SUMMARIZATION_PROVIDER=gemini
#ANTHROPIC_API_KEY=sk-ant-...               # required for claude
#CLAUDE_MODEL=claude-sonnet-4-6             # or opus-4-8, haiku-4-5

# ══ Local transcription (Whisper) ════════════════════════════════════════
# tiny | base | small | medium | large-v3 | turbo | distil-*.en (English, faster)
WHISPER_MODEL_SIZE=small

# Speaker labels for local Whisper (pyannote; ~2-3 GB RAM/VRAM when loaded).
# Enabled without HF_TOKEN and no cached models, transcription fails fast with a setup hint.
#LOCAL_DIARIZATION_ENABLED=true
# One-time download of the gated pyannote models — free token at hf.co/settings/tokens,
# then accept the terms on hf.co/pyannote/speaker-diarization-3.1 and
# hf.co/pyannote/segmentation-3.0. Not needed once the models are cached.
#HF_TOKEN=hf_...
# auto|cpu|cuda — set to cpu to keep VRAM flat while Whisper uses the GPU.
#DIARIZATION_DEVICE=cpu
# Name diarized speakers automatically from enrolled voice profiles (needs
# LOCAL_DIARIZATION_ENABLED=true; enroll voices via the transcript editor's
# "Remember voice" checkbox). Unmatched voices stay "Speaker N".
#SPEAKER_ID_ENABLED=true

# ══ Knowledge base / RAG ═════════════════════════════════════════════════
# Embeddings: gemini (cloud) | ollama (dockerized, shared) | local (in-process, non-Docker dev —
# see docs/knowledge-base.md)
EMBEDDING_PROVIDER=gemini
# Generation: gemini | ollama | local (ollama==local). Unset → follows EMBEDDING_PROVIDER.
#RAG_PROVIDER=gemini
# Ollama (provider=ollama/local). Dockerized: use the service name; models auto-pull on first start.
# Host Ollama instead: http://host.docker.internal:11434 + run Ollama with OLLAMA_HOST=0.0.0.0.
#OLLAMA_BASE_URL=http://ollama:11434
#OLLAMA_EMBEDDING_MODEL=bge-m3
#OLLAMA_MODEL=qwen2.5:7b                    # GPU & CPU; qwen2.5:3b = faster CPU
# Changing the embedding provider/model clears the vector store on startup — reload from Knowledge page.

# ══ Login / auth ═════════════════════════════════════════════════════════
AUTH_ENABLED=false
#AUTH_SECRET_KEY=your-secret-key-here

# ══ Docker & deployment (optional; defaults shown) ═══════════════════════
# GPU toggle (Linux+NVIDIA) — reserves the GPU for Whisper/diarization + Ollama.
#GPU=1
COMPOSE_FILE=compose.yaml${GPU:+:compose.gpu.yaml} #  COMPOSE_FILE sep ':' Linux, ';' Windows — see docs/docker.md
#INTERNAL_IP=127.0.0.1                      # Traefik host/domain — must match how you reach the server
#WEB_CONCURRENCY=4                          # uvicorn workers + upload concurrency
#CELERY_CONCURRENCY=1                       # parallel transcription jobs

# ══ Advanced (rarely needed — see docs before setting) ═══════════════════
# WHISPER_DEVICE / WHISPER_COMPUTE_TYPE → docs/transcription.md (non-Docker only; in Docker
#                                         compose pins both to `auto` — use GPU=1 instead)
# DIARIZATION_MODEL                     → docs/transcription.md
# SPEAKER_ID_THRESHOLD / _MARGIN        → min cosine similarity (default 0.5) and required lead
#                                         over the 2nd-best profile (0.05) to auto-name a speaker
# LOCAL_EMBEDDING_MODEL / _DEVICE       → docs/knowledge-base.md (EMBEDDING_PROVIDER=local)
# CELERY_BROKER_URL / TASK_LOCK_TTL     → docs/celery-guide.md
# CELERY_TASK_TIME_LIMIT                → docs/celery-guide.md (raise for very long recordings;
#   / CELERY_TASK_SOFT_TIME_LIMIT         default 1h — soft limit & lock TTL follow it)
