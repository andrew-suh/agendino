# ── Gemini (transcription, summarization, RAG) ───────────────────────────
GEMINI_API_KEY=your-gemini-api-key
# gemini-3-flash-preview | gemini-3.1-pro-preview | gemini-2.5-pro | gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── Summarization: gemini | claude ───────────────────────────────────────
SUMMARIZATION_PROVIDER=gemini
#ANTHROPIC_API_KEY=sk-ant-...               # required for claude
#CLAUDE_MODEL=claude-sonnet-4-6             # or opus-4-8, haiku-4-5

# ── Whisper (local transcription) ────────────────────────────────────────
# tiny | base | small | medium | large-v3 | turbo | distil-*.en (English, faster)
WHISPER_MODEL_SIZE=small
#WHISPER_DEVICE=auto                        # non-Docker only: auto|cpu|cuda|mps
#WHISPER_COMPUTE_TYPE=auto                  # auto|int8|float16|float32
# GPU Toggle (Linux+NVIDIA)
#GPU=1
COMPOSE_FILE=compose.yaml${GPU:+:compose.gpu.yaml} #  COMPOSE_FILE sep ':' Linux, ';' Windows — see docs/docker.md

# ── Notion ───────────────────────────────────────────────────────────────
NOTION_API_KEY=ntn_...
NOTION_PAGE_ID=your-parent-page-id-here

# ── App ──────────────────────────────────────────────────────────────────
DATABASE_NAME=agendino.db
AUTH_ENABLED=false
#AUTH_SECRET_KEY=your-secret-key-here

# ── Deployment / tuning (optional; defaults shown) ───────────────────────
#INTERNAL_IP=127.0.0.1                      # Traefik host/domain
#CELERY_BROKER_URL=redis://localhost:6379/0
#WEB_CONCURRENCY=4                          # uvicorn workers + upload concurrency
#CELERY_CONCURRENCY=1                       # parallel transcription jobs
#TASK_LOCK_TTL=1860                         # lock safety TTL (seconds)
