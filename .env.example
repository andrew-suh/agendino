# Required - Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key
# gemini-3.1-pro-preview | gemini-3-flash-preview | gemini-3.1-flash-lite-preview
# gemini-2.5-pro | gemini-2.5-flash | gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
# gemini-embedding-2-preview | gemini-embedding-001
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Summarization engine: gemini | claude (Claude can't transcribe audio, only summarize)
SUMMARIZATION_PROVIDER=gemini
# Required only for SUMMARIZATION_PROVIDER=claude
#ANTHROPIC_API_KEY=sk-ant-...
# claude-sonnet-4-6 (default) | claude-opus-4-8 | claude-haiku-4-5
#CLAUDE_MODEL=claude-sonnet-4-6

DATABASE_NAME=agendino.db

NOTION_API_KEY=ntn_...
NOTION_PAGE_ID=your-parent-page-id-here

# tiny | base | small | medium | large | large-v2 | large-v3 | turbo
# distil (English-only, faster): distil-small.en | distil-medium.en | distil-large-v2 | distil-large-v3
WHISPER_MODEL_SIZE=small
# auto (GPU if available, else CPU) | cpu | cuda | mps
WHISPER_DEVICE=cpu
# auto | int8 | int8_float16 | float16 | float32
WHISPER_COMPUTE_TYPE=auto

# Enable login (default: false)
AUTH_ENABLED=false

# ── Deployment / tuning (optional; defaults shown) ───────────────────────
# Host/domain for Traefik routing, e.g. 192.168.1.100 or agendino.local
#INTERNAL_IP=127.0.0.1
# Redis for Celery + task locks (override only for non-default Redis)
#CELERY_BROKER_URL=redis://localhost:6379/0
# uvicorn workers + dashboard upload concurrency
#WEB_CONCURRENCY=4
# Parallel Celery jobs; tune per CPU/GPU (docs/docker.md)
#CELERY_CONCURRENCY=1
# Task-lock safety TTL in seconds (keep above the task time limit)
#TASK_LOCK_TTL=1860
# Turn on GPU Whisper (Linux + NVIDIA Toolkit). Sep is ':' Linux, ';' Windows. See docs/docker.md
#COMPOSE_FILE=compose.yaml:compose.gpu.yaml
